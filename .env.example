# Email configuration for test automation
# Copy this file to .env and fill in your actual credentials
# NEVER commit .env file - it's in .gitignore

# Sender email configuration (SendinBlue SMTP)
SENDER_EMAIL=your-sender@example.com
SENDER_PASSWORD=your-sender-application-password
SENDER_SMTP_HOST=smtp-relay.com

# Receiver email configuration (for receiving test emails)
RECEIVER_EMAIL=your-receiver@example.com
RECEIVER_PASSWORD=your-receiver-application-password
