# Companion-mode local workspace — runtime artefacts from companion-mode runs
# (run-<N>/ subdirs, trigger-eval drafts, evidence bundles). Never tracked,
# never shipped via npm publish (the `discoverSkills` function in
# scripts/postinstall.js excludes it because it has no SKILL.md). Lives
# under skills/ for adjacency to the companion-mode skill itself.
skills/companion-mode-workspace/

# Hook runtime state — recreated by harness hooks on each run, never source.
tests/e2e/docs/.in-flight-composers.json
tests/e2e/docs/.coverage-expansion-cycle-*.json
tests/e2e/docs/onboarding-phase-ledger.json
tests/e2e/docs/coverage-expansion-state.json
tests/e2e/docs/.adversarial-findings.lock

# Subagent spillover bodies (§2.6 of subagent-return-schema.md) — written
# by reviewer / probe / etc. subagents on return; consumed by the next
# composer-cycle brief. Per-run state, never source.
tests/e2e/docs/.subagent-returns/
tests/e2e/docs/.handover-payloads/

# Per-PR contribution handover — local working artefact, validated by
# hooks/contribution-handover-gate.sh on push. Never committed; carrying
# the previous PR's handover into a new branch is the failure mode the
# gate exists to catch. The schema/template at
# .contribution-handover.template.json stays tracked.
/.contribution-handover.json

api-coverage-report.txt

.env
.env.local
/.yalc
yalc.lock
test-coverage-report.md
*.txt
!hooks/data/canonical-sections.txt
/docs
/skills/*-workspace
/solution-designs
